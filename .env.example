# --- Dados ---------------------------------------------------------------
# API-Football (api-sports.io) — histórico das seleções. Free: 100 req/dia.
API_FOOTBALL_KEY=sua_chave_aqui
API_FOOTBALL_HOST=v3.football.api-sports.io
WORLD_CUP_LEAGUE_ID=1
WORLD_CUP_SEASON=2026

# football-data.org — fixtures e resultados da Copa 2026. Free tier.
FOOTBALL_DATA_TOKEN=seu_token_aqui

# Caminho do banco SQLite.
DB_PATH=./copa.db

# --- API (opcionais) -----------------------------------------------------
# Atualização automática dos resultados (segundos). 0 desliga o agendador.
REFRESH_INTERVAL_SECONDS=3600
# Em produção, restrinja as origens (separadas por vírgula). Em dev, qualquer
# porta de localhost é aceita automaticamente.
# CORS_ORIGINS=https://seu-dominio.com
# Caminho do log de métricas de monitoramento.
METRICS_LOG=./metrics_log.csv
